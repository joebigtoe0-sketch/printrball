# Server (@powerball/server) loads this file from the monorepo root and apps/server/.env (override).
PORT=4000
DATA_DIR=./data
# Leave unset for apps/server/config/exclusions.json. Do not set EXCLUSIONS_PATH= alone (empty breaks saves).
EXCLUSIONS_PATH=
ROUND_LAUNCH_MS=
ROUND_LENGTH_MS=900000
# On mainnet, 60s+ reduces 429s if your RPC tier is tight (holder list is cached between polls).
HOLDER_POLL_MS=5000
# Set to 0 for production / mainnet holder pulls (needs TOKEN_MINT or mint in admin + RPC_URL)
MOCK_HOLDERS=1
MOCK_PRIZE_LAMPORTS=4231000000
METEORA_LIVE_ENABLED=0
# base58 secret key (or JSON array) for treasury wallet that owns Meteora positions and pays winner
TREASURY_PRIVATE_KEY=
# prize poll frequency (live Meteora mode)
PRIZE_POLL_MS=10000
# skip tiny claims
MIN_CLAIM_LAMPORTS=1
# keep a little SOL in treasury so fee payer never drains to zero
PAYOUT_RESERVE_LAMPORTS=2500000
TOKEN_MINT=
# Mainnet: set your Alchemy (or any Solana JSON-RPC) URL here. Helius is optional — only used if RPC_URL is empty.
RPC_URL=
# Optional: force holder scans to this URL. If unset, HELIUS_API_KEY (mainnet/devnet) is used for holders before RPC_URL, so Alchemy + Helius key together sends GPA to Helius.
HOLDER_RPC_URL=
HELIUS_API_KEY=
# devnet | mainnet | mainnet-beta — must match your mint (mainnet mint → mainnet-beta)
HELIUS_NETWORK=devnet
# Password for POST /api/admin/login and admin UI
ADMIN_PASSWORD=12345
CORS_ORIGIN=http://localhost:3000
TOKEN_TICKER=PRINTR
CREATOR_WALLET=
EXCLUSION_WALLETS=

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_TOKEN_TICKER=PRINTR
NEXT_PUBLIC_SOLSCAN_CLUSTER=devnet

# --- Go-live / mainnet test (typical) ---
# MOCK_HOLDERS=0
# RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
# HOLDER_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# HELIUS_NETWORK=mainnet-beta
# NEXT_PUBLIC_SOLSCAN_CLUSTER=mainnet-beta
# If you already ran dev rounds, clear persisted state so the site stays STANDBY until admin Start:
#   pnpm --filter @powerball/server reset-live
# (stops auto-resuming rounds from old data/history.json)
