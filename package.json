{
  "name": "powerball",
  "private": true,
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @powerball/server dev\" \"pnpm --filter @powerball/web dev\"",
    "dev:server": "pnpm --filter @powerball/server dev",
    "dev:web": "pnpm --filter @powerball/web dev",
    "build:server": "pnpm --filter @powerball/server build",
    "build:web": "pnpm --filter @powerball/web build",
    "start:server": "pnpm --filter @powerball/server start",
    "start:web": "pnpm --filter @powerball/web start",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
